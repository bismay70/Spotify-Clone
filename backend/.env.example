# Backend Environment Variables
# Copy this to .env and fill in your actual values

# Database - Choose ONE:

# Option 1: Local MongoDB (for development)
MONGODB_URI=mongodb://127.0.0.1:27017/spotify

# Option 2: MongoDB Atlas (for production)
# Make sure to:
# 1. Whitelist your IP at https://cloud.mongodb.com
# 2. Replace username, password, and cluster name
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spotifydb?retryWrites=true&w=majority

# Server Configuration
PORT=4000

# Cloudinary Configuration (for image/video uploads)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
